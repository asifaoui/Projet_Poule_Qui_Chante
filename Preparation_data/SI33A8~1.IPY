    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "\n",
        "#copie du dataframe zone_groups\n",
        "df_population_2000 = zone_groups.loc[zone_groups[2000].isnull(),:]\n",
        "\n",
        "pd.set_option('future.no_silent_downcasting', True)\n",
        "pd.options.mode.copy_on_write = True\n",
        "#détecter les colonnes année (ex : '2000')\n",
        "year_col = [c for c in df_population_2000.columns if re.search(r'\\b\\d{4}\\b', str(c))]\n",
        "\n",
        "#normaliser placeholders en NaN (ex: '..', '', 'NA')\n",
        "df_population_2000[year_col] = df_population_2000[year_col].replace(['..', '', 'NA', 'na', 'N/A'], np.nan)\n",
        "\n",
        "\n",
        "#remplissage des valeurs NaN en 2000 par la valeur la plus récente\n",
        "df_population_2000[2000] = df_population_2000[year_col].apply(Parcourir.first_valid_value_from_left, axis=1)"
      ],
      "metadata": {
        "id": "GJekGMgR_BAe"
      },
      "execution_count": 10,
      "outputs": []
    },
