    {
      "cell_type": "code",
      "source": [
        "#Définir une nouvelle variable Export_Utile qui est la différence entre Importations - Quantité et Exportations - Quantité\n",
        "#Si la différence est positive, l'export vers ce pays est utile\n",
        "#sinon, pas besoin d'exporter vers ce pays parce qu'il a assez de viande de volaille\n",
        "\n",
        "\n",
        "data_export_import['Export_Utile']= data_export_import['Importations - Quantité'] - data_export_import['Exportations - Quantité']\n",
        "\n",
        "data_export_import.head()\n"
      ],
