    {
      "cell_type": "code",
      "source": [
        "#copie du dataframe zone_groups\n",
        "df_population_18 = zone_groups.loc[zone_groups[2018].isnull(),:]\n",
        "pd.set_option('future.no_silent_downcasting', True)\n",
        "pd.options.mode.copy_on_write = True\n",
        "#détecter les colonnes année (ex : '2018')\n",
        "year_cols = [c for c in df_population_18.columns if re.search(r'\\b\\d{4}\\b', str(c))]\n",
        "\n",
        "#remplissage des valeurs NaN en 2018 par la valeur la plus récente\n",
        "df_population_18[2018] = df_population_18[year_cols].apply(Parcourir.last_valid_value_from_right, axis=1)\n",
        "\n",
        "zone_groups.loc[zone_groups[2018].isnull(),:] = df_population_18"
      ],
      "metadata": {
        "id": "m0PxWpsvCDsD"
      },
      "execution_count": 13,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Ajout d'une colonne pour le taux de croissance entre 2000 et 2018\n",
        "taux_croissance = (zone_groups.loc[:, 2018] - zone_groups.loc[:, 2000]) / zone_groups.loc[:, 2000] * 100\n",
        "zone_groups['taux_croissance'] = round(taux_croissance, 2)\n",
        "zone_groups.head()"
      ],
      "metadata": {
