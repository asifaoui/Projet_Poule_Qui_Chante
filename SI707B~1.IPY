      "source": [
        "# Groupe de zone avec les différents aliments pour tous les animaux\n",
        "zone_alimentation = df_alimentation_animale.pivot_table(index= ['Code zone','Zone'], columns= ['Produit'], values = 'Valeur')\n",
        "zone_alimentation.reset_index(inplace=True)\n",
        "zone_alimentation.shape"
