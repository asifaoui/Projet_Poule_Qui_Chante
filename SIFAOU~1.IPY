        "\n",
        "variable_dispo_calorie = ['Code zone','Zone','Disponibilité alimentaire (Kcal/personne/jour)']\n",
        "data_dispo_calorie = data_volaille_pivo[variable_dispo_calorie]\n",
        "data_dispo_calorie.head()"
      ]
