      "source": [
        "#Pivot pour avoir en colonne Code zone, Zone, Elements et Valeur\n",
        "data_volaille_pivo = data_volaille.pivot_table(index= ['Code zone','Zone'], columns= ['Élément'], values = 'Valeur')\n",
        "data_volaille_pivo.reset_index(inplace=True)\n",
        "data_volaille_pivo.head()"
      ],
